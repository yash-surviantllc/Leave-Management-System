NODE_ENV="development"
PORT="5000"
CORS_ORIGIN="http://localhost:3000"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lms?schema=public"
JWT_SECRET="replace-with-a-random-secret-at-least-32-characters"
JWT_EXPIRES_IN_SECONDS="86400"
PASSWORD_RESET_EXPIRES_IN_MINUTES="30"
REDIS_URL=""
DASHBOARD_CACHE_TTL_SECONDS="60"
PRISMA_CONNECTION_LIMIT="10"
PRISMA_POOL_TIMEOUT_SECONDS="20"
BUSINESS_TIME_ZONE="Asia/Kolkata"
SEED_ADMIN_PASSWORD="Admin@12345"
SEED_HR_PASSWORD="Hr@12345"
SEED_MANAGER_PASSWORD="Manager@12345"
SEED_EMPLOYEE_PASSWORD="Employee@12345"
PRISMA_QUERY_LOGS="false"
